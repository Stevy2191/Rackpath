# ---------------------------------------------------------------------------
# Rackpath environment configuration
# Copy this file to .env and adjust values for your deployment.
# ---------------------------------------------------------------------------

# ---- General ----
# Tag/version of the GHCR images to pull (e.g. latest, main, v1.0.0)
IMAGE_TAG=latest
GHCR_NAMESPACE=ghcr.io/stevy2191

# ---- MariaDB (rackpath-db) ----
# Root password for the MariaDB container. Only needed for admin tasks
# (e.g. running db/init.sql by hand) - the apps use MYSQL_USER below.
MYSQL_ROOT_PASSWORD=changeme_root_password
# Database name, and the app user/password used to connect to it.
# These three must match DB_NAME/DB_USER/DB_PASSWORD in the API section below.
MYSQL_DATABASE=rackpath
MYSQL_USER=rackpath
MYSQL_PASSWORD=changeme_password
# Host port that maps to MariaDB's port 3306 (set to "" to not publish it).
DB_PORT=3306

# ---- API (rackpath-api) ----
# Host port the API listens on and publishes.
API_PORT=3010
# Database connection details for the API. DB_HOST is the compose service
# name; DB_PORT_INTERNAL is MariaDB's port *inside* the compose network
# (always 3306, regardless of DB_PORT above). DB_USER/DB_PASSWORD/DB_NAME
# must match the MYSQL_* values above.
DB_HOST=rackpath-db
DB_PORT_INTERNAL=3306
DB_USER=rackpath
DB_PASSWORD=changeme_password
DB_NAME=rackpath

# Secret used to sign authentication JWTs. Generate a long random value, e.g.
# `openssl rand -hex 32`, and keep it secret - anyone with this value can
# forge valid login tokens.
RACKPATH_JWT_SECRET=changeme_use_a_long_random_string

# URL the API uses to reach the scanner service.
# rackpath-scanner runs with network_mode: host, so it is not reachable via
# its service name on the default bridge network - use the host gateway
# instead (the api service maps host.docker.internal -> host-gateway).
SCANNER_URL=http://host.docker.internal:5001

# Public base URL the scanner uses to call back into the API with results.
# The scanner runs on the host network, and the api service publishes
# API_PORT to the host, so localhost reaches it directly.
API_PUBLIC_URL=http://localhost:3010

# ---- Frontend (rackpath-frontend) ----
FRONTEND_PORT=8080
# Base URL the frontend uses to reach the API (set to your host/IP in production)
API_BASE_URL=http://localhost:3010

# ---- Scanner (rackpath-scanner) ----
SCANNER_PORT=5001
# Default SNMP v2c community string used for discovery
SNMP_COMMUNITY=public
# Default network interface used for scapy/ARP operations (host networking)
SCAN_INTERFACE=eth0
